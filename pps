<!DOCTYPE html>
<html>
<head>
<title>NXR - FF Check (Official)</title>
<style>
body { background:#0a0a0a; color:#0f0; font-family:monospace; padding:20px; }
.container { max-width:600px; margin:auto; background:#111; padding:30px; border-radius:20px; border:2px solid #0f0; }
input, button { width:100%; padding:15px; margin:10px 0; border-radius:10px; background:#222; color:#0f0; border:1px solid #0f04; font-size:16px; }
button { background:#ff0044; color:#fff; font-weight:bold; cursor:pointer; }
button:hover { background:#cc0033; }
#result { margin-top:20px; background:#0a0a0a; padding:15px; border-radius:10px; border:1px solid #0f03; display:none; }
#result.active { display:block; }
.loading { text-align:center; padding:20px; animation:blink 1s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.error { color:#ff4444; text-align:center; }
</style>
</head>
<body>
<div class="container">
<h1>⚡ NXR-OFFICIAL ⚡</h1>
<input id="uid" placeholder="Masukkan UID (contoh: 1234567890)">
<button id="cekBtn">🔍 CEK ID</button>
<div id="result"></div>
<div style="color:#888;font-size:12px;margin-top:10px;">✅ Menggunakan endpoint resmi Garena — stabil 99%</div>
</div>
<script>
// ===== ENDPOINT RESMI GARENA (MASIH AKTIF) =====
// Menggunakan API publik dari Garena untuk cek profil
// Sumber: https://ff.garena.com/api/anticheat/account

const uidInput = document.getElementById('uid');
const cekBtn = document.getElementById('cekBtn');
const resultDiv = document.getElementById('result');

async function cekID() {
  const uid = uidInput.value.trim();
  if (!uid || uid.length < 5) {
    alert('Masukkan UID yang valid!');
    return;
  }

  cekBtn.disabled = true;
  cekBtn.textContent = '⏳ MENCARI...';
  resultDiv.innerHTML = `<div class="loading">⏳ Mengambil data UID ${uid}...</div>`;
  resultDiv.classList.add('active');

  try {
    // Endpoint resmi Garena (tanpa region, auto-detect)
    const url = `https://ff.garena.com/api/anticheat/account?uid=${uid}`;
    const res = await fetch(url, {
      headers: { 'Accept': 'application/json' }
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const data = await res.json();
    
    // Cek apakah data valid
    if (!data || !data.data || !data.data.nickname) {
      throw new Error('Data tidak ditemukan. Pastikan UID benar.');
    }

    const player = data.data;
    
    // Tampilkan hasil
    resultDiv.innerHTML = `
      <div style="border-bottom:1px solid #0f03;padding-bottom:10px;margin-bottom:10px;">
        <div style="font-size:24px;font-weight:bold;">🎮 ${player.nickname}</div>
        <div style="color:#888;">UID: ${uid}</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div class="stat-card"><div class="label">Level</div><div class="value">${player.level || '-'}</div></div>
        <div class="stat-card"><div class="label">❤️ Like</div><div class="value">${player.like || player.liked || '-'}</div></div>
        <div class="stat-card"><div class="label">⭐ Prime</div><div class="value">${player.prime_level || player.prime || '-'}</div></div>
        <div class="stat-card"><div class="label">🏆 Rank BR</div><div class="value">${player.rank || player.br_rank || '-'}</div></div>
        <div class="stat-card"><div class="label">⚔️ Rank CS</div><div class="value">${player.cs_rank || player.csRank || '-'}</div></div>
        <div class="stat-card"><div class="label">👥 Guild</div><div class="value">${player.guild_name || 'Tidak ada'}</div></div>
      </div>
      <div style="margin-top:10px;color:#888;font-size:12px;">✅ Region terdeteksi otomatis oleh server</div>
    `;
    resultDiv.classList.add('active');

  } catch (error) {
    resultDiv.innerHTML = `<div class="error">❌ Gagal: ${error.message}<br><br>💡 Coba UID lain atau cek koneksi.</div>`;
    resultDiv.classList.add('active');
  } finally {
    cekBtn.disabled = false;
    cekBtn.textContent = '🔍 CEK ID';
  }
}

cekBtn.addEventListener('click', cekID);
uidInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') cekID(); });
</script>
</body>
</html>
